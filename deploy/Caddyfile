# Caddy auto-HTTPS reverse proxy for the no-Coolify VPS deploy.
# Hostnames come from the environment (set in .env.cloud). Use sslip.io hosts
# (e.g. app.<server-ip>.sslip.io) for a domain-free deploy, or your own domain.
# Caddy obtains and renews Let's Encrypt certs automatically.

{$APP_FQDN} {
	# Structured access log persisted to the caddy_data volume. Answers "who's
	# using this" (UI page hits) and "is anything broken" (4xx/5xx rates). See
	# the Monitoring section in deploy/DEPLOY.md for query snippets.
	log {
		output file /data/access.log {
			roll_size 10MiB
			roll_keep 5
		}
		format json
	}
	reverse_proxy web:80
}

{$N8N_FQDN} {
	# Same access log as the app host. Filter request.uri for /webhook/ here to
	# count chat questions actually asked (a pageview is not a conversation).
	log {
		output file /data/access.log {
			roll_size 10MiB
			roll_keep 5
		}
		format json
	}

	# Public liveness check for uptime monitoring. n8n's built-in /healthz
	# returns 200 {"status":"ok"} instantly without running any workflow, so an
	# external monitor can confirm n8n is alive without burning LLM tokens or
	# hanging on the streaming chat trigger. Exposes no data.
	@health path /healthz
	handle @health {
		reverse_proxy n8n:5678
	}

	# Only the public chat webhook is internet-facing. The editor UI, /rest, and
	# /signin are managed via docker exec on the internal Docker network, so they
	# need no public exposure.
	@webhook path /webhook/*
	handle @webhook {
		# Per-client IP rate limiting (the chat webhook is public and
		# unauthenticated). The burst zone cuts floods off within seconds; the
		# sustained zone caps slow-drip abuse. Either trip returns HTTP 429.
		# Nothing proxies in front of this VPS, so {remote_host} is the real
		# client IP.
		rate_limit {
			zone chat_burst {
				key {remote_host}
				events 5
				window 10s
			}
			zone chat_sustained {
				key {remote_host}
				events 20
				window 1m
			}
		}
		# Bound per-call LLM cost: chat POST bodies are small.
		request_body {
			max_size 16KB
		}
		reverse_proxy n8n:5678
	}

	handle {
		abort
	}
}

{$QDRANT_FQDN} {
	reverse_proxy qdrant:6333
}
