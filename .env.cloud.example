# Cloud stack (Vultr VPS, no Coolify). Copy to .env.cloud on the server.
# Use sslip.io hostnames for a domain-free deploy (replace 203.0.113.10 with your
# server's public IP), or swap in your own domain.

# Public hostnames Caddy serves (TLS via Let's Encrypt).
APP_FQDN=app.203.0.113.10.sslip.io
N8N_FQDN=n8n.203.0.113.10.sslip.io
QDRANT_FQDN=qdrant.203.0.113.10.sslip.io

# n8n public URL settings (must match N8N_FQDN).
N8N_HOST=n8n.203.0.113.10.sslip.io
N8N_PUBLIC_URL=https://n8n.203.0.113.10.sslip.io
N8N_EDITOR_BASE_URL=https://n8n.203.0.113.10.sslip.io
WEBHOOK_URL=https://n8n.203.0.113.10.sslip.io/

# Chat UI origin for CORS (must match APP_FQDN).
APP_PUBLIC_URL=https://app.203.0.113.10.sslip.io

# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Same value on the qdrant service and the n8n credential expression.
QDRANT__SERVICE__API_KEY=
QDRANT_API_KEY=

OPENROUTER_API_KEY=

# Cloudflare Web Analytics beacon token (optional). Create a site at
# Cloudflare dashboard > Analytics & Logs > Web Analytics, then paste the token
# from the JS snippet here. Leave blank to disable analytics.
CF_BEACON_TOKEN=

# Email alerts for the n8n error workflow (workflow run failures). The
# "SMTP (alerts)" credential is imported from n8n/cloud/credentials/smtp.json
# and reads these values, so no n8n UI access is needed.
# SMTP_HOST/USER/PASSWORD come from your provider (Gmail app password, Resend,
# SendGrid, etc.). SMTP_PORT 465 with secure TLS is the default the credential
# expects; for a 587/STARTTLS provider set SMTP_PORT=587 and change "secure" to
# false in n8n/cloud/credentials/smtp.json.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# ALERT_EMAIL_FROM is the sender your SMTP provider allows; ALERT_EMAIL_TO is
# where alerts are delivered.
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
