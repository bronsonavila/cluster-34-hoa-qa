POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

# Local-only placeholders. Replace these (and the Postgres password above) with strong, unique values before any non-local deployment.
N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# OpenRouter API key - used for both the reasoning LLM and embeddings.
OPENROUTER_API_KEY=

# Remote Qdrant on the VPS (HTTPS + API key). Required for local ingestion after cloud deploy.
# Example: https://qdrant.example.com
QDRANT_PUBLIC_URL=
QDRANT_API_KEY=

# Email alerts for the n8n error workflow (workflow run failures). The
# "SMTP (alerts)" credential is imported from n8n/credentials/smtp.json and
# reads these values. SMTP_HOST/USER/PASSWORD come from your provider (Gmail
# app password, Resend, SendGrid, etc.). For a 587/STARTTLS provider set
# SMTP_PORT=587 and change "secure" to false in n8n/credentials/smtp.json.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# ALERT_EMAIL_FROM is the sender your SMTP provider allows; ALERT_EMAIL_TO is
# where alerts are delivered.
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
